# ──────────────────────────────────────────────
# FREMOR GLOBAL — Email Server Config
# ──────────────────────────────────────────────
# Copy this file as .env and fill in your values
# NEVER commit .env to git!

# ── Your Gmail address ──
GMAIL_USER=your.email@gmail.com

# ── Gmail App Password (NOT your normal password) ──
# Steps to get it:
#   1. Go to your Google Account → Security
#   2. Enable 2-Step Verification (if not already)
#   3. Search "App Passwords" in Google Account settings
#   4. Create one → choose "Mail" → copy the 16-char password
GMAIL_APP_PASSWORD=rvej kgax rxlv bmxy

# ── Where enquiry emails should be delivered ──
RECEIVER_EMAIL=your.email@gmail.com

# ── Port for this server (default 5000) ──
PORT=5000

# ── Frontend URL (for CORS) ──
FRONTEND_URL=http://localhost:5173
